<%- include('../partials/layout') %>
<div class="auth-page">
  <div class="auth-card animate-fadeIn">
    <div class="auth-header">
      <div style="font-size:2.5rem;margin-bottom:0.5rem;">🔑</div>
      <h2><%= lang === 'bn' ? 'পাসওয়ার্ড ভুলে গেছেন?' : 'Forgot Password?' %></h2>
      <p><%= lang === 'bn' ? 'আপনার ইমেইলে রিসেট লিংক পাঠানো হবে' : 'We\'ll send a reset link to your email' %></p>
    </div>
    <form action="/auth/forgot" method="POST">
      <div class="form-group">
        <label class="form-label"><%= lang === 'bn' ? 'ইমেইল' : 'Email Address' %></label>
        <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block"><%= lang === 'bn' ? 'রিসেট লিংক পাঠান' : 'Send Reset Link' %></button>
    </form>
    <div class="auth-footer"><a href="/auth/login"><%= lang === 'bn' ? '← লগইনে ফিরুন' : '← Back to Login' %></a></div>
  </div>
</div>
<%- include('../partials/footer') %>
