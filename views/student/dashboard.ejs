<%- include('../partials/layout') %>

<div class="dashboard-layout">
  <%- include('../partials/sidebar', {active: 'dashboard', role: 'student'}) %>
  <div class="main-content">
    <!-- Mobile sidebar toggle -->
    <div style="display:none;" id="mobileSidebarBtn" class="mb-2">
      <button id="sidebarToggle" class="sidebar-mobile-toggle">☰ Menu</button>
    </div>

    <!-- ===================== Sattacademy-style dashboard (matches app screenshot) ===================== -->
    <div class="sa-dashboard">

      <!-- Top bar -->
      <div class="sa-topbar">
        <div class="sa-topbar-left">
          <span class="sa-topbar-title"><%= lang==='bn'?'ড্যাশবোর্ড':'Dashboard' %></span>
        </div>
        <div class="sa-topbar-right">
          <div class="sa-xp-badge">⚡ <%= xp %> XP</div>
          <a href="/materials/search" class="sa-icon-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          </a>
          <div class="sa-icon-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
          </div>
          <a href="/student/profile" style="text-decoration:none;">
            <% if (avatarUrl) { %>
              <img class="sa-avatar" src="<%= avatarUrl %>" alt="profile">
            <% } else { %>
              <div class="sa-avatar sa-avatar-fallback"><%= (user.name || 'S').charAt(0).toUpperCase() %></div>
            <% } %>
          </a>
        </div>
      </div>

      <!-- Notification ticker -->
      <div class="sa-ticker">
        <span><span class="sa-live-dot"></span><%= lang==='bn'?'সর্বশেষ':'Latest' %></span>
        <% notifications.forEach(function(n){ %>
          <span><span class="bolt">⚡</span><%= n %></span>
        <% }) %>
      </div>

      <!-- Upgrade banner -->
      <div class="sa-upgrade-card">
        <div class="sa-upgrade-title">আপগ্রেড করুন</div>
        <div class="sa-upgrade-row">
          <p class="sa-upgrade-text">সকল ফিচারে এক্সেস পেতে যেকোনো একটি প্যাকেজ সাবস্ক্রাইব করুন।</p>
          <a href="/courses/pricing" class="sa-upgrade-btn">সাবস্ক্রাইব করুন</a>
        </div>
        <div class="sa-upgrade-toggle">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </div>
      </div>

      <!-- Icon grid -->
      <div class="sa-icon-grid">
        <a href="/materials" class="sa-icon-item">
          <div class="sa-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 8 12 3 3 8l9 5 9-5Z"/><path d="M3 8v8l9 5 9-5V8"/></svg></div>
          <span>প্রশ্ন ব্যাংক</span>
        </a>
        <a href="/exam/browse" class="sa-icon-item">
          <div class="sa-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="m10 8 6 4-6 4Z"/></svg></div>
          <span>প্র্যাকটিস</span>
        </a>
        <a href="/exam/setup?type=mock" class="sa-icon-item">
          <div class="sa-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></div>
          <span>মক টেস্ট</span>
        </a>
        <a href="/exam/history" class="sa-icon-item">
          <div class="sa-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 21h8M12 17v4M7 4h10v4a5 5 0 0 1-10 0V4Z"/><path d="M7 6H4a3 3 0 0 0 3 5M17 6h3a3 3 0 0 1-3 5"/></svg></div>
          <span>লিডারবোর্ড</span>
        </a>
        <a href="/exam/setup" class="sa-icon-item">
          <div class="sa-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="6" y="3" width="12" height="18" rx="2"/><path d="m9 13 2 2 4-4"/></svg></div>
          <span>এক্সাম</span>
        </a>
        <a href="/materials?type=book" class="sa-icon-item">
          <div class="sa-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19V5a2 2 0 0 1 2-2h12v18H6a2 2 0 0 1-2-2Z"/><path d="M18 21V3"/></svg></div>
          <span>বুক</span>
        </a>
        <a href="/courses" class="sa-icon-item">
          <div class="sa-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="13" rx="2"/><path d="m10 9 5 3-5 3Z"/></svg></div>
          <span>কোর্স</span>
        </a>
        <a href="/exam/setup?mode=battle" class="sa-icon-item">
          <div class="sa-icon-box"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="8" width="20" height="9" rx="3"/><path d="M7 12h.01M10 12h3M16 11v2M18 12h.01"/></svg></div>
          <span>ব্যাটেল</span>
        </a>
      </div>

      <!-- Streak card -->
      <div class="sa-streak-card">
        <div class="sa-streak-top">
          <span class="sa-streak-fire">🔥</span>
          <span class="sa-streak-label"><%= lang==='bn'?'চলমান স্ট্রিক':'Current Streak' %></span>
        </div>
        <div class="sa-streak-count">
          <%= streak %><span> <%= lang==='bn'?'দিন':'Day' %></span>
        </div>
        <p class="sa-streak-hint"><%= lang==='bn'?'স্ট্রিক শুরু করতে কিছু MCQ প্র্যাকটিস করুন! 🔥':'Practice some MCQ to start your streak! 🔥' %></p>
      </div>

      <!-- Study stats -->
      <div class="sa-stats-header">
        <h4><%= lang==='bn'?'গত ৭ দিনের স্টাডি স্ট্যাটস':'Your Study Stats Last 7 Days' %></h4>
        <div class="sa-tab-group">
          <button class="sa-tab active" data-range="7">7D</button>
          <button class="sa-tab" data-range="15">15D</button>
          <button class="sa-tab" data-range="30">30D</button>
        </div>
      </div>

      <div class="sa-stats-grid">
        <div class="sa-stat-card">
          <div class="sa-stat-card-head">
            <span>STUDY TIME</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          </div>
          <div class="sa-stat-value"><%= studyTimeLabel %></div>
        </div>

        <div class="sa-stat-card">
          <div class="sa-stat-card-head">
            <span>Accuracy</span>
            <a href="/exam/history">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <%
            const radius = 50, circumference = 2 * Math.PI * radius;
            const offset = circumference - (accuracyPercent / 100) * circumference;
          %>
          <div class="sa-accuracy-ring">
            <svg viewBox="0 0 120 120" width="120" height="120">
              <circle class="track" cx="60" cy="60" r="<%= radius %>"></circle>
              <circle class="progress" cx="60" cy="60" r="<%= radius %>"
                      stroke-dasharray="<%= circumference %>"
                      stroke-dashoffset="<%= offset %>"></circle>
            </svg>
            <div class="sa-accuracy-value"><%= accuracyPercent %>%</div>
          </div>
        </div>
      </div>

    </div>
    <!-- ===================== end Sattacademy-style dashboard ===================== -->

    <!-- Extra detail section (desktop-friendly, not shown in the mobile screenshot but kept for full functionality) -->
    <div style="margin-top:2rem;">

      <!-- Overall stats -->
      <div class="stat-cards">
        <div class="stat-card">
          <div class="stat-card-icon">📝</div>
          <div class="stat-card-val"><%= examCount %></div>
          <div class="stat-card-label"><%= lang==='bn'?'মোট পরীক্ষা':'Total Exams' %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon">📊</div>
          <div class="stat-card-val"><%= avgScore %>%</div>
          <div class="stat-card-label"><%= lang==='bn'?'গড় স্কোর':'Average Score' %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon">📚</div>
          <div class="stat-card-val"><%= purchases.length %></div>
          <div class="stat-card-label"><%= lang==='bn'?'এনরোল্ড কোর্স':'Enrolled Courses' %></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon">🏅</div>
          <div class="stat-card-val"><%= avgScore>=80?'A+':avgScore>=70?'A':avgScore>=60?'B':avgScore>=50?'C':'—' %></div>
          <div class="stat-card-label"><%= lang==='bn'?'গ্রেড':'Grade' %></div>
        </div>
      </div>

      <!-- Category Browse -->
      <div style="margin-bottom:2rem;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
          <div style="font-weight:800;font-size:1rem;color:var(--text);">📁 <%= lang==='bn'?'বিভাগ অনুযায়ী পড়াশোনা':'Browse by Category' %></div>
        </div>
        <div class="cat-grid">
          <a href="/materials?level=ssc&stream=science" class="cat-card">
            <span class="cat-icon">🔬</span>
            <div class="cat-name">SSC <%= lang==='bn'?'বিজ্ঞান':'Science' %></div>
            <div class="cat-count"><%= lang==='bn'?'পদার্থ, রসায়ন, জীব':'Physics, Chem, Bio' %></div>
          </a>
          <a href="/materials?level=ssc&stream=arts" class="cat-card">
            <span class="cat-icon">📜</span>
            <div class="cat-name">SSC <%= lang==='bn'?'মানবিক':'Arts' %></div>
            <div class="cat-count"><%= lang==='bn'?'বাংলা, ইতিহাস, ভূগোল':'Bangla, History, Geo' %></div>
          </a>
          <a href="/materials?level=ssc&stream=commerce" class="cat-card">
            <span class="cat-icon">💼</span>
            <div class="cat-name">SSC <%= lang==='bn'?'বাণিজ্য':'Commerce' %></div>
            <div class="cat-count"><%= lang==='bn'?'হিসাব, অর্থনীতি':'Accounting, Economics' %></div>
          </a>
          <a href="/materials?level=hsc&stream=science" class="cat-card">
            <span class="cat-icon">⚗️</span>
            <div class="cat-name">HSC <%= lang==='bn'?'বিজ্ঞান':'Science' %></div>
            <div class="cat-count"><%= lang==='bn'?'পদার্থ, রসায়ন, জীব, গণিত':'Phys, Chem, Bio, Math' %></div>
          </a>
          <a href="/materials?level=hsc&stream=arts" class="cat-card">
            <span class="cat-icon">🎨</span>
            <div class="cat-name">HSC <%= lang==='bn'?'মানবিক':'Arts' %></div>
            <div class="cat-count"><%= lang==='bn'?'বাংলা সাহিত্য, দর্শন':'Bangla Lit, Philosophy' %></div>
          </a>
          <a href="/materials?level=hsc&stream=commerce" class="cat-card">
            <span class="cat-icon">📊</span>
            <div class="cat-name">HSC <%= lang==='bn'?'বাণিজ্য':'Commerce' %></div>
            <div class="cat-count"><%= lang==='bn'?'হিসাব, ব্যবস্থাপনা':'Accounts, Management' %></div>
          </a>
        </div>
      </div>

      <!-- Quick Actions + Recent Exams grid -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">

        <!-- Quick Actions -->
        <div class="table-wrap" style="padding:1.5rem;">
          <div style="font-weight:800;font-size:0.95rem;color:var(--text);margin-bottom:1.25rem;">⚡ <%= lang==='bn'?'দ্রুত কার্যক্রম':'Quick Actions' %></div>
          <div style="display:flex;flex-direction:column;gap:0.75rem;">
            <a href="/exam/setup" class="btn btn-primary" style="justify-content:flex-start;gap:0.75rem;">
              📝 <%= lang==='bn'?'পরীক্ষা শুরু করুন':'Start a Practice Exam' %>
            </a>
            <a href="/materials" class="btn btn-secondary" style="justify-content:flex-start;gap:0.75rem;">
              📚 <%= lang==='bn'?'PDF ডাউনলোড করুন':'Download PDF Materials' %>
            </a>
            <a href="/courses" class="btn btn-secondary" style="justify-content:flex-start;gap:0.75rem;">
              🎓 <%= lang==='bn'?'কোর্স দেখুন':'Browse Courses' %>
            </a>
            <a href="/exam/history/all" class="btn btn-secondary" style="justify-content:flex-start;gap:0.75rem;">
              📊 <%= lang==='bn'?'পরীক্ষার ইতিহাস':'View Exam History' %>
            </a>
          </div>
        </div>

        <!-- Recent Exams -->
        <div class="table-wrap" style="padding:1.5rem;">
          <div style="font-weight:800;font-size:0.95rem;color:var(--text);margin-bottom:1.25rem;">📋 <%= lang==='bn'?'সাম্প্রতিক পরীক্ষা':'Recent Exams' %></div>
          <% if (recentExams.length) { %>
            <% recentExams.forEach(function(e) { %>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:0.75rem 0;border-bottom:1px solid var(--border);">
              <div>
                <div style="font-size:0.85rem;font-weight:600;color:var(--text);"><%= e.subject || (e.level.toUpperCase()+' '+e.stream) %></div>
                <div style="font-size:0.72rem;color:var(--text3);margin-top:0.1rem;"><%= new Date(e.created_at).toLocaleDateString('en-BD') %></div>
              </div>
              <div>
                <% if (e.score !== null && e.total_questions) { %>
                  <% var p = Math.round(e.score/e.total_questions*100); %>
                  <span class="badge <%= p>=80?'badge-success':p>=60?'badge-warning':'badge-danger' %>"><%= e.score %>/<%= e.total_questions %></span>
                <% } else { %>
                  <a href="/exam/<%= e.id %>" class="badge badge-warning" style="text-decoration:none;"><%= lang==='bn'?'চলমান':'Resume' %></a>
                <% } %>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <div style="text-align:center;padding:2rem;color:var(--text3);font-size:0.85rem;">
              <div style="font-size:2rem;margin-bottom:0.5rem;">📝</div>
              <%= lang==='bn'?'এখনো কোনো পরীক্ষা দেননি':'No exams yet' %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- Submit Review -->
      <div class="table-wrap" style="padding:1.5rem;">
        <div style="font-weight:800;font-size:0.95rem;color:var(--text);margin-bottom:1.25rem;">⭐ <%= lang==='bn'?'আপনার মতামত দিন':'Share Your Review' %></div>
        <form action="/student/review" method="POST" style="display:flex;gap:1rem;flex-wrap:wrap;align-items:flex-end;">
          <div class="form-group" style="min-width:120px;margin:0;">
            <label class="form-label"><%= lang==='bn'?'রেটিং':'Rating' %></label>
            <select name="rating" class="form-control" style="width:auto;">
              <option value="5">⭐⭐⭐⭐⭐</option>
              <option value="4">⭐⭐⭐⭐</option>
              <option value="3">⭐⭐⭐</option>
              <option value="2">⭐⭐</option>
              <option value="1">⭐</option>
            </select>
          </div>
          <div class="form-group" style="flex:1;min-width:220px;margin:0;">
            <label class="form-label"><%= lang==='bn'?'মন্তব্য':'Your Review' %></label>
            <input type="text" name="review_text" class="form-control" placeholder="<%= lang==='bn'?'আপনার অভিজ্ঞতা শেয়ার করুন...':'Share your experience...' %>" required>
          </div>
          <button type="submit" class="btn btn-primary"><%= lang==='bn'?'জমা দিন':'Submit' %></button>
        </form>
      </div>

    </div>
  </div>
</div>

<!-- Floating chat button -->
<div class="sa-chat-fab">
  <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" width="22" height="22"><path d="M21 11.5a8.38 8.38 0 0 1-9 8.4A8.5 8.5 0 1 1 21 11.5Z"/></svg>
</div>

<!-- Bottom navigation (mobile) -->
<div class="sa-bottom-nav">
  <a href="/exam/setup" class="sa-nav-item">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m5 4 8 8-8 8M13 4l8 8-8 8"/></svg>
    <%= lang==='bn'?'প্র্যাকটিস':'Practice' %>
  </a>
  <a href="/materials" class="sa-nav-item">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m13 2-2 9h7l-9 11 2-9H4Z"/></svg>
    <%= lang==='bn'?'প্রশ্ন ব্যাংক':'Ques. Bank' %>
  </a>
  <a href="/student" class="sa-nav-home">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 12 9-9 9 9"/><path d="M5 10v10h14V10"/></svg>
  </a>
  <a href="/exam/setup?mode=battle" class="sa-nav-item">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>
    <%= lang==='bn'?'ব্রেইন ক্ল্যাশ':'Brain Clash' %>
  </a>
  <a href="/exam/history" class="sa-nav-item">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 8h6M9 12h6M9 16h4"/></svg>
    <%= lang==='bn'?'এক্সাম':'Exams' %>
  </a>
</div>

<script>
// Lightweight study-time tracker: pings the server every 30s the tab is visible & focused
(function(){
  let seconds = 0;
  setInterval(function(){
    if (document.visibilityState === 'visible' && document.hasFocus()) {
      seconds += 30;
      fetch('/student/track-time', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ seconds: 30 })
      }).catch(function(){});
    }
  }, 30000);
})();
</script>

<%- include('../partials/footer') %>
