<%- include('../partials/layout') %>
<div style="padding-top:70px;min-height:100vh;background:var(--bg);">
<div class="container" style="padding:3rem 1rem;max-width:900px;">
  <div class="breadcrumb"><a href="/courses"><%= lang==='bn'?'কোর্স':'Courses' %></a><span>›</span><span><%= course.title %></span></div>

  <div style="display:grid;grid-template-columns:1fr 340px;gap:2rem;align-items:start;">
    <div>
      <div style="margin-bottom:0.75rem;">
        <span class="badge badge-primary"><%= course.level.toUpperCase() %></span>
        <span class="badge badge-secondary" style="margin-left:0.5rem;"><%= course.stream %></span>
      </div>
      <h1 style="font-size:1.8rem;font-weight:900;color:var(--text);margin-bottom:1rem;line-height:1.3;">
        <%= lang==='bn'&&course.title_bn ? course.title_bn : course.title %>
      </h1>
      <div class="course-rating" style="margin-bottom:1rem;">
        <span class="stars">⭐⭐⭐⭐⭐</span>
        <span class="rating-count">(<%= course.enrolled_count %> <%= lang==='bn'?'শিক্ষার্থী':'students' %>)</span>
      </div>
      <p style="color:var(--text2);line-height:1.8;margin-bottom:2rem;">
        <%= lang==='bn'&&course.description_bn ? course.description_bn : course.description %>
      </p>

      <h3 style="font-weight:800;margin-bottom:1rem;"><%= lang==='bn'?'কোর্সে কী আছে:':'What\'s included:' %></h3>
      <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:2rem;">
        <% [
          lang==='bn'?'📹 ভিডিও লেকচার':'📹 Video Lectures',
          lang==='bn'?'📝 লাইভ MCQ পরীক্ষা':'📝 Live MCQ Practice',
          lang==='bn'?'📄 PDF নোটস':'📄 PDF Notes',
          lang==='bn'?'🎯 সাবজেক্টভিত্তিক প্রশ্নব্যাংক':'🎯 Subject-wise Question Bank',
          lang==='bn'?'👨‍🏫 শিক্ষকের সাথে সরাসরি সেশন':'👨‍🏫 Direct Teacher Sessions',
        ].forEach(item => { %>
        <div style="display:flex;align-items:center;gap:0.75rem;font-size:0.9rem;color:var(--text);">
          <span style="color:var(--success);font-weight:700;">✓</span> <%= item %>
        </div>
        <% }) %>
      </div>

      <div style="display:flex;gap:1rem;align-items:center;padding:1.25rem;background:var(--bg3);border-radius:var(--radius);border:1px solid var(--border);">
        <div style="font-size:2.5rem;">👨‍🏫</div>
        <div>
          <div style="font-weight:700;color:var(--text);"><%= course.instructor||'Parafin Expert' %></div>
          <div style="font-size:0.82rem;color:var(--text3);">Course Instructor</div>
        </div>
      </div>
    </div>

    <!-- Sticky Sidebar -->
    <div style="position:sticky;top:90px;">
      <div class="table-wrap" style="padding:1.75rem;">
        <% if(course.thumbnail) { %>
        <img src="/uploads/<%= course.thumbnail %>" alt="<%= course.title %>" style="width:100%;border-radius:10px;margin-bottom:1.25rem;object-fit:cover;height:160px;">
        <% } %>
        <div style="font-size:2rem;font-weight:900;color:var(--primary);margin-bottom:0.25rem;">
          <%= course.price==0?(lang==='bn'?'বিনামূল্যে':'Free'):'৳'+course.price %>
        </div>
        <% if(course.original_price>course.price) { %>
        <div style="font-size:0.9rem;color:var(--text3);text-decoration:line-through;margin-bottom:1rem;">৳<%= course.original_price %></div>
        <% } %>

        <div style="display:flex;flex-direction:column;gap:0.6rem;margin-bottom:1.5rem;font-size:0.85rem;color:var(--text2);">
          <div>⏱️ <%= lang==='bn'?'মেয়াদ':'Duration' %>: <%= course.duration||'—' %></div>
          <div>📖 <%= lang==='bn'?'মোট ক্লাস':'Total Classes' %>: <%= course.total_lessons %></div>
          <div>👥 <%= lang==='bn'?'শিক্ষার্থী':'Students' %>: <%= course.enrolled_count %></div>
        </div>

        <% if(purchased) { %>
        <div class="alert alert-success" style="margin-bottom:0;">✅ <%= lang==='bn'?'আপনি এই কোর্সে ভর্তি আছেন!':'You are enrolled!' %></div>
        <% } else { %>
        <button onclick="purchaseCourse(<%= course.id %>,<%= course.price %>)" class="btn btn-primary btn-block btn-lg">
          🚀 <%= lang==='bn'?'এখনই ভর্তি হন':'Enroll Now' %>
        </button>
        <% } %>
      </div>
    </div>
  </div>
</div>
</div>

<!-- Purchase Modal -->
<div class="modal-overlay" id="purchaseModal">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">🛒 <%= lang==='bn'?'কোর্স কিনুন':'Purchase Course' %></span>
      <button class="modal-close" onclick="closeModal('purchaseModal')">✕</button>
    </div>
    <% if(!user) { %>
      <p style="margin-bottom:1.5rem;color:var(--text2);"><%= lang==='bn'?'কোর্স কিনতে লগইন করুন।':'Login to purchase.' %></p>
      <a href="/auth/login" class="btn btn-primary btn-block">Login</a>
    <% } else { %>
    <form action="/courses/purchase" method="POST">
      <input type="hidden" name="course_id" id="purchaseCourseId">
      <div class="form-group">
        <label class="form-label"><%= lang==='bn'?'মূল্য':'Amount' %>: <strong id="purchaseAmount"></strong></label>
      </div>
      <div class="form-group">
        <label class="form-label"><%= lang==='bn'?'পেমেন্ট পদ্ধতি':'Payment' %></label>
        <select name="payment_method" class="form-control">
          <option value="bkash">bKash</option>
          <option value="nagad">Nagad</option>
          <option value="rocket">Rocket</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label"><%= lang==='bn'?'ট্রানজেকশন আইডি':'Transaction ID' %></label>
        <input type="text" name="transaction_id" class="form-control" placeholder="BK..." required>
      </div>
      <button type="submit" class="btn btn-primary btn-block">✅ Confirm</button>
    </form>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
