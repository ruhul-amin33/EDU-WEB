<%- include('../partials/layout') %>
<div class="dashboard-layout">
  <%- include('../partials/sidebar', {active:'exam-results', role:'admin'}) %>
  <div class="main-content">

    <div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem;">
      <div>
        <div class="page-title">📊 Exam Results</div>
        <div class="page-subtitle">View every completed student exam and export the full list to Excel</div>
      </div>
      <a href="/admin/exam-results/export?<%= new URLSearchParams(filters).toString() %>" class="btn btn-success btn-lg">
        📥 Download Excel (.xlsx)
      </a>
    </div>

    <!-- Summary cards -->
    <div class="stat-cards">
      <div class="stat-card">
        <div class="stat-card-icon">📝</div>
        <div class="stat-card-val"><%= summary.total_exams || 0 %></div>
        <div class="stat-card-label">Total Completed Exams</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon">👥</div>
        <div class="stat-card-val"><%= summary.total_students || 0 %></div>
        <div class="stat-card-label">Students Who Took Exams</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon">📈</div>
        <div class="stat-card-val"><%= summary.avg_score ? Math.round(summary.avg_score) : 0 %>%</div>
        <div class="stat-card-label">Overall Average Score</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-icon">📋</div>
        <div class="stat-card-val"><%= exams.length %></div>
        <div class="stat-card-label">Showing (filtered, max 500)</div>
      </div>
    </div>

    <!-- Filters -->
    <div class="table-wrap" style="padding:1.25rem 1.5rem;margin-bottom:1.5rem;">
      <form method="GET" style="display:flex;gap:.75rem;flex-wrap:wrap;align-items:flex-end;">
        <div class="form-group" style="margin:0;min-width:160px;flex:1;">
          <label class="form-label">Search Student</label>
          <input type="text" name="search" class="form-control" placeholder="Name or email..." value="<%= filters.search||'' %>">
        </div>
        <div class="form-group" style="margin:0;min-width:110px;">
          <label class="form-label">Level</label>
          <select name="level" class="form-control">
            <option value="">All</option>
            <option value="ssc" <%= filters.level==='ssc'?'selected':'' %>>SSC</option>
            <option value="hsc" <%= filters.level==='hsc'?'selected':'' %>>HSC</option>
            <option value="admission" <%= filters.level==='admission'?'selected':'' %>>Admission</option>
          </select>
        </div>
        <div class="form-group" style="margin:0;min-width:130px;">
          <label class="form-label">Stream</label>
          <select name="stream" class="form-control">
            <option value="">All</option>
            <option value="science" <%= filters.stream==='science'?'selected':'' %>>Science</option>
            <option value="arts" <%= filters.stream==='arts'?'selected':'' %>>Arts</option>
            <option value="commerce" <%= filters.stream==='commerce'?'selected':'' %>>Commerce</option>
          </select>
        </div>
        <div class="form-group" style="margin:0;min-width:150px;">
          <label class="form-label">Subject</label>
          <select name="subject" class="form-control">
            <option value="">All Subjects</option>
            <% subjects.forEach(function(s){ %><option value="<%= s.subject %>" <%= filters.subject===s.subject?'selected':'' %>><%= s.subject %></option><% }) %>
          </select>
        </div>
        <div class="form-group" style="margin:0;min-width:140px;">
          <label class="form-label">From Date</label>
          <input type="date" name="from_date" class="form-control" value="<%= filters.from_date||'' %>">
        </div>
        <div class="form-group" style="margin:0;min-width:140px;">
          <label class="form-label">To Date</label>
          <input type="date" name="to_date" class="form-control" value="<%= filters.to_date||'' %>">
        </div>
        <button type="submit" class="btn btn-primary">Filter</button>
        <a href="/admin/exam-results" class="btn btn-secondary">Reset</a>
      </form>
    </div>

    <!-- Results table -->
    <div class="table-wrap">
      <div class="table-scroll">
      <table>
        <thead><tr>
          <th>#</th><th>Student</th><th>Level</th><th>Stream</th><th>Subject</th>
          <th>Score</th><th>%</th><th>Grade</th><th>Completed</th>
        </tr></thead>
        <tbody>
          <% if (exams.length) { %>
            <% exams.forEach(function(e, i) { %>
            <% var pct = e.total_questions ? Math.round(e.score / e.total_questions * 100) : 0; %>
            <% var grade = pct>=80?'A+':pct>=70?'A':pct>=60?'B':pct>=50?'C':'F'; %>
            <tr>
              <td><%= i+1 %></td>
              <td>
                <div style="font-weight:600;font-size:.88rem;"><%= e.student_name %></div>
                <div style="font-size:.75rem;color:var(--text3);"><%= e.student_email %></div>
              </td>
              <td><span class="badge badge-primary"><%= e.level.toUpperCase() %></span></td>
              <td style="font-size:.85rem;"><%= e.stream %></td>
              <td style="font-size:.85rem;"><%= e.subject || 'Mixed' %></td>
              <td><%= e.score %>/<%= e.total_questions %></td>
              <td><span class="badge <%= pct>=80?'badge-success':pct>=60?'badge-warning':'badge-danger' %>"><%= pct %>%</span></td>
              <td><strong><%= grade %></strong></td>
              <td style="font-size:.8rem;"><%= new Date(e.completed_at).toLocaleString('en-BD') %></td>
            </tr>
            <% }) %>
          <% } else { %>
          <tr><td colspan="9" style="text-align:center;padding:3rem;color:var(--text3);">No completed exams found for these filters.</td></tr>
          <% } %>
        </tbody>
      </table>
      </div>
    </div>

  </div>
</div>
<%- include('../partials/footer') %>
